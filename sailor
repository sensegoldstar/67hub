        end
        
        if foundWave and currentWaveNum and maxWaveNum then
            -- ถ้าเลข wave ลดลง (เช่นจาก 15 กลับมาเป็น 1, 2, หรือ 3) แสดงว่าเริ่มดันใหม่
            if previousWave > 0 and currentWaveNum < previousWave then
                -- ถ้าดันก่อนหน้าไปถึง wave สุดท้าย (อนุโลมให้ >= max-1 เผื่อหลุด)
                if previousWave >= (lastMaxWave - 1) then
                    dungeonCompletedCount = dungeonCompletedCount + 1
                end
            end
            
            previousWave = currentWaveNum
            lastMaxWave = maxWaveNum
            
            pcall(function()
                DungeonCountStatus:Set({ 
                    Title   = "จำนวนรอบที่จบดันเจี้ยน", 
                    Content = "สำเร็จไปแล้ว: " .. dungeonCompletedCount .. " รอบ\n(Wave ปัจจุบัน: " .. currentWaveNum .. "/" .. maxWaveNum .. ")"
                })
            end)
        end
    end
end)

