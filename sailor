                                selectedMobPrefixes[prefix] = nil
                            end
                        end,
                    })
                    table.insert(dynamicMobToggles, tgl)
                end
            end
        end
    end

    if foundNew > 0 then
        Rayfield:Notify({ Title = "Scan Mobs", Content = "เพิ่มมอนใหม่ " .. foundNew .. " ตัวลงในเมนูแล้ว", Duration = 3 })
