-- ตรวจว่าอยู่ใน Dungeon (เช็คชื่อ Workspace หรือ PlaceId ย่อย)
local function isInsideDungeon()
    -- เช็ค Attribute หรือ tag ใน Workspace ที่เกมบางเกมตั้งไว้
    local ws = game:GetService("Workspace")
    if ws:GetAttribute("InDungeon") then return true end
    -- เช็คชื่อ Lighting หรือ Skybox ที่เฉพาะดัน
    local lighting = game:GetService("Lighting")
    if lighting and lighting:FindFirstChild("DungeonAmbience") then return true end
    -- fallback: เช็คว่า Map ใน Workspace มีชื่อ Dungeon อยู่
    for _, child in ipairs(Workspace_:GetChildren()) do
        if child.Name:lower():find("dungeon") then return true end
    end
    return false
end

-- ค้นหามอนในดัน — ค้นใน workspace.NPCs โดยตรง (ไว) + fallback ทั้ง workspace
local function findDungeonMob()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    -- ค้นใน workspace.NPCs ก่อน (มอนดันอยู่ที่นี่) ถ้าไม่มีค่อย fallback ทั้ง workspace
    local searchList = {}
    local npcFolder = Workspace_:FindFirstChild("NPCs")
    if npcFolder then
        for _, obj in ipairs(npcFolder:GetChildren()) do
            table.insert(searchList, obj)
        end
    end
    -- ถ้าหา NPCs ไม่เจอ หรือหาแล้วไม่เจอมอน ให้ค้น workspace ทั้งหมดเป็น fallback
    if #searchList == 0 then
        for _, obj in ipairs(Workspace_:GetChildren()) do
            table.insert(searchList, obj)
        end
    end

    local nearest, bestDist = nil, math.huge
    for _, obj in ipairs(searchList) do
        if obj:IsA("Model") and obj ~= myChar then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            -- ไม่กรองชื่อ NPC ออก เพราะมอนดันชื่อ DungeonNPC1, DungeonNPC2 ฯลฯ
            if hum and hum.Health > 0 and hum.MaxHealth > 10 then
                local anchor = obj:FindFirstChild("HumanoidRootPart")
                    or obj:FindFirstChild("Torso")
                    or obj.PrimaryPart
                if anchor then
                    local d = (anchor.Position - myRoot.Position).Magnitude
                    if d < bestDist then
                        nearest  = obj
                        bestDist = d
                    end
                end
            end
        end
    end
    return nearest
end

-- Tween เข้าหามอนดัน
local dungeonTweening = false
local function tweenToDungeonMob(mob)
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local anchor = mob:FindFirstChild("HumanoidRootPart")
        or mob:FindFirstChild("Torso")
        or mob.PrimaryPart
    if not myRoot or not anchor then return false end

    local dist = (anchor.Position - myRoot.Position).Magnitude
    if dist <= 8 then
        return true -- อยู่ในระยะแล้ว
    end

    if not dungeonTweening then
        dungeonTweening = true
        task.spawn(function()
            local targetCF = CFrame.lookAt(anchor.Position + Vector3.new(0, 0, 3), anchor.Position)
            local t = dist / tweenSpeed
            local tw = TweenService:Create(myRoot, TweenInfo.new(t, Enum.EasingStyle.Linear), {CFrame = targetCF})
            tw:Play()
            tw.Completed:Wait()
            dungeonTweening = false
        end)
    end
    return false
end

-- ชน/โจมตีมอนดัน
local function attackDungeonMob(mob)
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local mobHRP = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Torso")
    if not myRoot or not mobHRP then return end
    pcall(function() myRoot.CFrame = CFrame.lookAt(myRoot.Position, mobHRP.Position) end)
    pcall(function() CombatRemote:FireServer() end)
end

-- ── Main Auto Dungeon Loop ─────────────────────────────────────
local function startAutoDungeonLoop()
    task.spawn(function()
        -- ─ Step 1: วาปไปเกาะ Dungeon ─
        dungeonPhase = "warp_island"
        dungeonSetStatus("🚀 Step 1", "วาปไปเกาะ Dungeon...")
        dungeonTeleportIsland("Dungeon")
        task.wait(4)  -- รอโหลดแมพ

        if not autoDungeonEnabled then return end

        -- ─ Step 2: วาปหา NPC ─
        dungeonPhase = "warp_npc"
        dungeonSetStatus("🧭 Step 2", "วาปไปหา DungeonPortalsNPC...")
        local found = false
        for i = 1, 10 do
            if warpToDungeonNPC() then found = true; break end
            task.wait(1)
        end
        if not found then
            dungeonSetStatus("❌ Error", "หา DungeonPortalsNPC ไม่เจอ — รีสตาร์ท Auto Dungeon")
            autoDungeonEnabled = false
            return
        end
        task.wait(1)

        if not autoDungeonEnabled then return end

        -- ─ Step 3: ขอเข้า Dungeon ─
        dungeonPhase = "spawn"
        dungeonSetStatus("🏰 Step 3", "เปิดพอร์ทัล: " .. selectedDungeon)
        fireRequestDungeonPortal(selectedDungeon)
        task.wait(2)

        if not autoDungeonEnabled then return end

        -- ─ Step 4: รอเข้าดัน (นับถอยหลัง 30 วิ) ─
        dungeonPhase = "waiting"
        local waitMax = 45
        for i = 1, waitMax do
            if not autoDungeonEnabled then return end
            dungeonSetStatus("⏳ Step 4 — รอเข้าดัน", "กำลังรอ countdown... (" .. (waitMax - i) .. "s)")
            task.wait(1)
            -- ถ้าตัวละครเด้งเข้าดันแล้วออกจากลูปได้เลย
            if isInsideDungeon() then break end
        end

        -- จบ — เข้าดันแล้ว ปิด toggle อัตโนมัติ
        dungeonPhase = "idle"
        autoDungeonEnabled = false
        dungeonSetStatus("✅ เข้าดันแล้ว!", "อยู่ใน " .. selectedDungeon .. " แล้ว\nเปิด ⚔️ Auto Kill Mob เพื่อฟาร์มได้เลย")
    end)
end


