-- ── รับเควสของมอนที่เลือกที่มีเลเวลสูงที่สุด (Silent) ────────────────────────
local function acceptHighestSelectedQuest()
    local highestLevel = -1
    local targetNpc = nil
    
    for prefix, _ in pairs(selectedMobPrefixes) do
        local entry = QUEST_MAP[prefix]
        if entry and entry.level and entry.level > highestLevel then
            highestLevel = entry.level
            targetNpc = entry.npc
        end
    end
    
    if targetNpc then
        -- ยิงรัว 2 รอบเผื่อเซิร์ฟเวอร์ดีเลย์ (เซิร์ฟเวอร์ Roblox มักจะ Dropped Remote บ่อย)
        for i = 1, 2 do
            pcall(function()
                ReplicatedStorage:WaitForChild("RemoteEvents")
                    :WaitForChild("QuestAccept"):FireServer(targetNpc)
            end)
            task.wait(0.1)
        end
    end
end

