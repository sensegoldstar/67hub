-- ── ระบบบินหาแท่นวาร์ป (Island Hopping Helper) ─────────────────────────
local function TweenFunction(targetCFrame, speed)
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = Character and Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local dist = (root.Position - targetCFrame.Position).Magnitude
    if dist < 1 then root.CFrame = targetCFrame; return end

    local moveSpeed = speed or tweenSpeed
    local timeToMove = dist / moveSpeed
    local tweenInfo = TweenInfo.new(timeToMove, Enum.EasingStyle.Linear)

    local bv = root:FindFirstChild("FarmFloat")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "FarmFloat"
        bv.MaxForce = Vector3.new(100000, 100000, 100000)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = root
    else
        bv.MaxForce = Vector3.new(100000, 100000, 100000)
    end

    if _G.currentTween then pcall(function() _G.currentTween:Cancel() end) end
    
    _G.isTweening = true
    local tween = TweenService:Create(root, tweenInfo, {CFrame = targetCFrame})
    _G.currentTween = tween
    tween:Play()
    tween.Completed:Wait()
    _G.isTweening = false
    
    if root then
        root.Velocity = Vector3.new(0, 0, 0)
        root.RotVelocity = Vector3.new(0, 0, 0)
    end
end

-- ฟังก์ชันสำหรับซ่อน/ปิดหน้าต่าง Teleport ที่ค้างอยู่บนจอ
local function CloseTeleportUI()
    pcall(function()
        local pg = LocalPlayer:FindFirstChild("PlayerGui")
        if pg then
            for _, gui in ipairs(pg:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Enabled then
                    local n = gui.Name:lower()
                    -- ถ้าชื่อ UI มีคำเหล่านี้ ให้ซ่อนทันที
                    if n:find("teleport") or n:find("map") or n:find("portal") then
                        gui.Enabled = false
                    else
                        -- ค้นหาตัวหนังสือข้างในเผื่อเกมตั้งชื่อ ScreenGui เป็นอย่างอื่น
                        for _, desc in ipairs(gui:GetDescendants()) do
                            if (desc:IsA("TextLabel") or desc:IsA("TextButton")) and desc.Text:lower():find("teleport") then
                                gui.Enabled = false
                                break
                            end
                        end
                    end
                end
            end
        end
    end)
end

local function HopToIsland(targetIsland)
    if _G.isIslandHopping then return end
    
    local timeSinceLastHop = tick() - (_G.lastPortalHop or 0)
    if timeSinceLastHop < 10 then 
        pcall(function() FarmStatus:Set({ Title = "⏳ รอ Cooldown สลับเกาะ", Content = "รออีก " .. math.ceil(10 - timeSinceLastHop) .. " วินาที..." }) end)
        return 
    end

    _G.isIslandHopping = true
    _G.lastPortalHop = tick()

    task.spawn(function()
        pcall(function() FarmStatus:Set({ Title = "✈️ กำลังบินข้ามเกาะ...", Content = "กำลังค้นหาแท่นวาร์ปเพื่อไป: " .. targetIsland }) end)

        local portalPart = nil
        local targetPrompt = nil
        for _, obj in ipairs(Workspace_:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local actText = (obj.ActionText or ""):lower():gsub("%s+", "")
                local objText = (obj.ObjectText or ""):lower():gsub("%s+", "")
                local name = obj.Name:lower():gsub("%s+", "")
                local pName = (obj.Parent and obj.Parent.Name or ""):lower():gsub("%s+", "")
                
                if string.find(actText, "openmap") or string.find(objText, "teleport") or 
                   string.find(actText, "teleport") or string.find(objText, "map") or
                   string.find(name, "portal") or string.find(pName, "portal") then
                    portalPart = obj.Parent
                    targetPrompt = obj
                    break
                end
            end
        end

        if portalPart and portalPart:IsA("BasePart") then
            pcall(function() FarmStatus:Set({ Title = "✈️ สลับเกาะ", Content = "เจอแท่นวาร์ปแล้ว กำลังบินไปกด..." }) end)
            TweenFunction(portalPart.CFrame * CFrame.new(0, 3, 0), tweenSpeed)
            task.wait(0.5)
            
            if targetPrompt and fireproximityprompt then
                pcall(function() fireproximityprompt(targetPrompt) end)
                task.wait(0.5)
            end
            
            pcall(function() game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("TeleportToPortal"):FireServer(targetIsland) end)
            task.wait(4)
            
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                 LocalPlayer.Character.HumanoidRootPart.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 50, 0)
            end
            
            -- ปิดหน้าต่าง UI Teleport ที่ค้างอยู่บนหน้าจอ
            CloseTeleportUI()
        else
            pcall(function() FarmStatus:Set({ Title = "⚠️ สลับเกาะ", Content = "อยู่ไกลแท่นวาร์ปเกินไป (แมพไม่โหลด)\nกำลังรีเซ็ตตัวละครเพื่อกลับจุดเกิด..." }) end)
            task.wait(1.5)
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalPlayer.Character.Humanoid.Health = 0 end
            task.wait(5) 
        end
        _G.isIslandHopping = false
    end)
end

