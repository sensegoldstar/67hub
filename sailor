local toolCache = {}
local typedWeaponName = ""
local autoEquipWeapon = false

local function getAllTools()
    local tools = {}
    local currentBackpack = LocalPlayer:FindFirstChild("Backpack")
    if currentBackpack then
        for _, item in ipairs(currentBackpack:GetChildren()) do
            if item:IsA("Tool") then table.insert(tools, item) end
        end
    end
    if Character then
        for _, item in ipairs(Character:GetChildren()) do
            if item:IsA("Tool") then table.insert(tools, item) end
        end
    end
    return tools
end

local function equipTool(tool)
    if not Character then return end
    local hum = Character:FindFirstChildOfClass("Humanoid")
    if hum then
        if tool.Parent ~= Character then
            hum:EquipTool(tool)
        end
    else
        local currentBackpack = LocalPlayer:FindFirstChild("Backpack")
        for _, item in ipairs(Character:GetChildren()) do
            if item:IsA("Tool") and currentBackpack then item.Parent = currentBackpack end
        end
        tool.Parent = Character
    end
end

