-- ========== FLY FUNCTIONS ==========
local function startFlying()
    if flying then return end
    flying = true
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bodyVelocity.Parent = humanoidRootPart
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bodyGyro.P = 9e4
    bodyGyro.Parent = humanoidRootPart
    
    print("🚀 Flying started!")
end

local function stopFlying()
    if not flying then return end
    flying = false
    
    if bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
    
    if bodyGyro then
        bodyGyro:Destroy()
        bodyGyro = nil
    end
    
    print("🛬 Flying stopped")
end

local function updateFlyDirection()
    if not flying then return end
    
    local camera = workspace.CurrentCamera
    local cameraCFrame = camera.CFrame
    
    local direction = Vector3.new(0, 0, 0)
    
    if moveDirection.forward then
        direction = direction + (cameraCFrame.LookVector * flySpeed)
    end
    if moveDirection.backward then
        direction = direction - (cameraCFrame.LookVector * flySpeed)
    end
    if moveDirection.left then
        direction = direction - (cameraCFrame.RightVector * flySpeed)
    end
    if moveDirection.right then
        direction = direction + (cameraCFrame.RightVector * flySpeed)
    end
    if moveDirection.up then
        direction = direction + Vector3.new(0, heightSpeed, 0)
    end
    if moveDirection.down then
        direction = direction - Vector3.new(0, heightSpeed, 0)
    end
    
    if bodyVelocity then
        bodyVelocity.Velocity = direction
    end
    
    if bodyGyro then
        bodyGyro.CFrame = cameraCFrame
    end
end

-- ========== AUTO COLLECT FUNCTIONS ==========
local function findAllBrainrots()
    local brainrots = {}
    local rarityFolders = {"Celestial", "Common", "Epic", "Godly", "Legendary", "Mythic", "Rare", "Secret"}
    
    pcall(function()
        local gameFolder = workspace:FindFirstChild("GameFolder")
        if gameFolder then
            local brainrotsFolder = gameFolder:FindFirstChild("Brainrots")
            if brainrotsFolder then
                for _, rarityName in ipairs(rarityFolders) do
                    local rarityFolder = brainrotsFolder:FindFirstChild(rarityName)
                    if rarityFolder then
                        for _, brainrot in pairs(rarityFolder:GetChildren()) do
                            if brainrot:IsA("Model") then
                                local primaryPart = brainrot.PrimaryPart or brainrot:FindFirstChildWhichIsA("BasePart")
                                if primaryPart then
                                    table.insert(brainrots, {
                                        name = brainrot.Name,
                                        rarity = rarityName,
                                        position = primaryPart.Position,
                                        object = brainrot
                                    })
                                end
                            elseif brainrot:IsA("BasePart") then
                                table.insert(brainrots, {
                                    name = brainrot.Name,
                                    rarity = rarityName,
                                    position = brainrot.Position,
                                    object = brainrot
                                })
                            end
                        end
                    end
                end
            end
        end
    end)
    
    return brainrots
end

local function teleportTo(position)
    if humanoidRootPart then
        humanoidRootPart.CFrame = CFrame.new(position)
    end
end

local function collectBrainrot(brainrotObject)
    local VirtualInputManager = game:GetService("VirtualInputManager")
    
    -- Try all methods
    pcall(function()
        local proximityPrompt = brainrotObject:FindFirstChildWhichIsA("ProximityPrompt", true)
        if proximityPrompt then
            fireproximityprompt(proximityPrompt)
        end
    end)
    
    pcall(function()
        local clickDetector = brainrotObject:FindFirstChildWhichIsA("ClickDetector", true)
        if clickDetector then
            fireclickdetector(clickDetector)
        end
    end)
    
    -- Press E multiple times
    for i = 1, 3 do
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        wait(0.05)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        wait(0.05)
    end
    
    -- Hold E key
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    wait(3)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    wait(0.5)
    
    return true
end

local function startAutoCollect()
    if autoCollecting then return end
    autoCollecting = true
    brainrotsCollected = 0
    
    print("🚀 Auto-collect Brainrot started!")
    
    spawn(function()
        while autoCollecting do
            local allBrainrots = findAllBrainrots()
            
            -- Filter by rarity
            local brainrots = {}
            for _, brainrot in ipairs(allBrainrots) do
                if selectedRarities[brainrot.rarity] then
                    table.insert(brainrots, brainrot)
                end
            end
            
            if #brainrots > 0 then
                for i, brainrot in ipairs(brainrots) do
                    if not autoCollecting then break end
                    
                    local originalPosition = humanoidRootPart.CFrame
                    
                    teleportTo(brainrot.position)
                    wait(0.3)
                    
                    collectBrainrot(brainrot.object)
                    
                    humanoidRootPart.CFrame = originalPosition
                    
                    brainrotsCollected = brainrotsCollected + 1
                    wait(collectDelay)
                end
            end
            
            wait(3)
        end
    end)
end

local function stopAutoCollect()
    if not autoCollecting then return end
    autoCollecting = false
    print("⏸️ Auto-collect stopped")
end

