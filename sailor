-- ── Find nearest selected mob ─────────────────────────────────
local function getMobAnchor(obj)
    -- คืน BasePart สำหรับตำแหน่งมอน (เผื่อไม่ต้องมี HumanoidRootPart)
    local anchor = obj:FindFirstChild("HumanoidRootPart")
        or obj:FindFirstChild("Torso")
        or obj:FindFirstChild("UpperTorso")
        or obj.PrimaryPart
    
    if anchor and anchor:IsA("BasePart") then return anchor end
    
    -- ค้นหาชิ้นส่วนแรกที่เจอในโมเดลเพื่อให้มีจุดวาปไปหาให้ได้
    for _, child in ipairs(obj:GetDescendants()) do
        if child:IsA("BasePart") and child.Name ~= "HumanoidRootPart" then
            return child
        end
    end
    
    return nil
end

local mobCache = {}
local lastCacheTick = 0

local function updateMobCache()
    local now = tick()
    if now - lastCacheTick < 1 then return end
    lastCacheTick = now
    
    local newCache = {}
    local myChar = LocalPlayer.Character
    local worldMobs = Workspace_:GetDescendants()
    
    _G.loadedSelectedPrefixes = {} -- เก็บรายชื่อมอนว่าเกาะไหนถูกโหลดแล้วบ้าง (รวมตัวที่ตายแล้ว)
    
    for i = 1, #worldMobs do
        local obj = worldMobs[i]
        if obj and obj:IsA("Model") and obj ~= myChar and not string.find(obj.Name, "NPC") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum then
                local cleanName = obj.Name:gsub("%s+", ""):lower()
                -- ตรวจสอบว่าชื่อมอนสเตอร์มี prefix ที่เราติ๊กเลือกไว้หรือไม่
                local isSelected = false
                for prefix, isEn in pairs(selectedMobPrefixes) do
                    local cleanPrefix = prefix:gsub("%s+", ""):lower()
                    if isEn and string.find(cleanName, cleanPrefix, 1, true) then
                        isSelected = true
                        _G.loadedSelectedPrefixes[prefix] = true
                        break
                    end
                end
                
                if isSelected and hum.Health > 0 then
                    table.insert(newCache, obj)
                end
            end
        end
    end
    mobCache = newCache
end

local currentMobTarget = nil

local function findNearestSelectedMob()
    updateMobCache()
    Character = LocalPlayer.Character or Character
    local root = Character and Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    -- ล็อคเป้าหมายเดิมไว้จนกว่าจะตาย หรือหายไปจากสารบบ
    if currentMobTarget and currentMobTarget.Parent then
        local targetHum = currentMobTarget:FindFirstChildOfClass("Humanoid")
        if targetHum and targetHum.Health > 0 then
            -- เช็คชัวร์ๆ ว่ายังอยู่ใน Cache จริงๆ (บางเกมขยะศพไม่ยอมลบ หรือเลือดบัค)
            local stillExists = false
            for _, m in ipairs(mobCache) do
                if m == currentMobTarget then stillExists = true; break end
            end
            if stillExists then
                return currentMobTarget
            end
        end
    end
    
    local nearest, bestDist = nil, math.huge
    for _, obj in ipairs(mobCache) do
        if obj and obj.Parent then
            local anchor = getMobAnchor(obj)
            local hum    = obj:FindFirstChildOfClass("Humanoid")
            if anchor and hum and hum.Health > 0 then
                local d = (anchor.Position - root.Position).Magnitude
                if d < bestDist then nearest = obj; bestDist = d end
            end
        end
    end
    
    currentMobTarget = nearest
    return nearest
end

-- ── Teleport ──────────────────────────────────────────────────
-- _G.isTweening เพื่อป้องกันการวาปซ้อนทับกันเวลาบินไกลๆ
_G.isTweening = false

local function TweenFunction(targetCFrame, speed)
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = Character and Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local dist = (root.Position - targetCFrame.Position).Magnitude
    if dist < 1 then 
        root.CFrame = targetCFrame
        return 
    end

    local moveSpeed = speed or tweenSpeed
    local timeToMove = dist / moveSpeed
    local tweenInfo = TweenInfo.new(timeToMove, Enum.EasingStyle.Linear)

    -- ตรวจสอบ FarmFloat จะได้บินแบบไม่ร่วง
    local bv = root:FindFirstChild("FarmFloat")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "FarmFloat"
        bv.MaxForce = Vector3.new(100000, 100000, 100000)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = root
    else
        bv.MaxForce = Vector3.new(100000, 100000, 100000)
    end

    if _G.currentTween then pcall(function() _G.currentTween:Cancel() end) end
    
    _G.isTweening = true
    local tween = TweenService:Create(root, tweenInfo, {CFrame = targetCFrame})
    _G.currentTween = tween
    tween:Play()
    
    tween.Completed:Wait()
    _G.isTweening = false
    
    if root then
        root.Velocity = Vector3.new(0, 0, 0)
        root.RotVelocity = Vector3.new(0, 0, 0)
    end
end

local function teleportBehindMob(mob)
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root   = Character and Character:FindFirstChild("HumanoidRootPart")
    local anchor = getMobAnchor(mob)
    
    if root and anchor and anchor:IsA("BasePart") then
        local offset = math.max(1.5, attackRange - 1)
        local targetCFrame = nil
        
        -- fallback protection in case anchor has no CFrame somehow
        if not pcall(function()
            if teleportPosition == "ด้านบน (Above)" then
                local overheadPos = anchor.CFrame * CFrame.new(0, offset, 0)
                targetCFrame = CFrame.lookAt(overheadPos.Position, anchor.Position)
                
            elseif teleportPosition == "ด้านล่าง (Below)" then
                local belowPos = anchor.CFrame * CFrame.new(0, -offset, 0)
                targetCFrame = CFrame.lookAt(belowPos.Position, anchor.Position)
                
            else
                local behindPos = anchor.CFrame * CFrame.new(0, 0, offset)
                targetCFrame = CFrame.lookAt(behindPos.Position, anchor.Position)
            end
        end) then
            return false
        end
        
        -- ถ้าอยู่ไกลมากกว่า 1500 studs แปลว่าข้ามเกาะ การบิน (Tween) หรือวาร์ปสดจะโดนเตะ (Error 267) ทันที
        -- ต้องใช้วิธีเข้า Portal แบบลัด (Fast Portal) เพื่อ Bypass Anti-Cheat
        local dist = (root.Position - anchor.Position).Magnitude
        if dist > 1500 then
            local targetIsland = nil
            local cleanName = mob.Name:gsub("%s+", ""):lower()
            
            -- หาว่ามอนตัวนี้อยู่เกาะไหนจาก QUEST_MAP
            for prefix, mapped in pairs(QUEST_MAP) do
                if string.find(cleanName, prefix:gsub("%s+", ""):lower(), 1, true) then
                    targetIsland = mapped.island
                    break
                end
            end
            
            if targetIsland and not _G.isIslandHopping then
                _G.isIslandHopping = true
                
                -- หน่วงเวลาล่วงหน้าเพื่อป้องกันบัค Error 773 และ 267 (สแปม Portal)
                if tick() - (_G.lastPortalHop or 0) > 15 then
                    _G.lastPortalHop = tick()
                    task.spawn(function()
                        pcall(function()
                            FarmStatus:Set({ Title = "✈️ สลับเกาะ (ลัด)", Content = "วาร์ปไป: " .. targetIsland })
                            game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("TeleportToPortal"):FireServer(targetIsland)
                        end)
                        
                        -- รอโหลดแมพและตัวละครกันโดนเตะ
                        task.wait(2)
                        
                        -- กันเด้งทะลุแมพตอนสปอนด์
                        if Character and Character:FindFirstChild("HumanoidRootPart") then
                             Character.HumanoidRootPart.CFrame = Character.HumanoidRootPart.CFrame * CFrame.new(0, 50, 0)
                        end
                        
                        task.wait(1)
                        _G.isIslandHopping = false
                    end)
                else
                    _G.isIslandHopping = false
                end
            end
            
            -- ปล่อยผ่านไปให้ลูปรอบหน้ามาจัดการวาปเข้าหลังมอนระยะประชิด
            return false -- Indicate that teleport is not finished (island hopping)
            
        else
            -- ถ้ากำลังข้ามเกาะอยู่ หรือมีสถานะวาร์ปข้ามโลก ห้ามขยับตัวเด็ดขาด (กัน Error 267)
            if _G.isIslandHopping then return false end
            
            -- ถ้าอยู่ใกล้ๆ (เกาะเดียวกัน)
            local distFromTarget = (root.Position - targetCFrame.Position).Magnitude
            
            -- แก้เป็นระบบ Tween ทั้งหมด เพราะเกมแก้ TP มา (Anti-Cheat ตรวจสอบการวาร์ป)
            if distFromTarget > 1 then
                if not _G.isTweening then
                    task.spawn(function()
                        TweenFunction(targetCFrame)
                    end)
                end
                return false -- ยังบินไม่ถึง
            else
                -- ถ้าระยะใกล้มากแล้ว (หรือ Tween เสร็จแล้ว)
                return true -- ถึงระยะพร้อมโจมตี
            end
        end
    end
    return false
end

-- ── Attack ────────────────────────────────────────────────────
-- The most reliable exploit attack method:
-- 1. Expand hitbox via CFrame loop (stay on top → triggers server-side damage)
-- 2. firetouchinterest on all mob parts
-- 3. VirtualUser mouse click toward mob center on screen
-- Remote ของเกมสำหรับโจมตี
local CombatRemote = ReplicatedStorage
    :WaitForChild("CombatSystem")
    :WaitForChild("Remotes")
    :WaitForChild("RequestHit")

local function attackMob(mob)
    local root   = Character and Character:FindFirstChild("HumanoidRootPart")
    local mobHRP = mob:FindFirstChild("HumanoidRootPart")
    if not root or not mobHRP then return end

    -- หันหน้าเข้าหามอนก่อนตี
    pcall(function()
        root.CFrame = CFrame.lookAt(root.Position, mobHRP.Position)
    end)

    -- ยิง Remote ตีมอนตามระบบเกม (เล่น animation ปกติ)
    pcall(function()
        CombatRemote:FireServer()
    end)
end

