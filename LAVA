                TweenService:Create(checkbox, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 60, 75)}):Play()
            end
        end)
    end
    
    -- Start/Stop Button
    local collectButton = Instance.new("TextButton")
    collectButton.Size = UDim2.new(1, 0, 0, 45)
    collectButton.Position = UDim2.new(0, 0, 0, 220)
    collectButton.BackgroundColor3 = Color3.fromRGB(50, 200, 100)
    collectButton.BorderSizePixel = 0
    collectButton.Text = "▶️ Start Auto-Collect"
    collectButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    collectButton.TextSize = 16
    collectButton.Font = Enum.Font.GothamBold
    collectButton.Parent = collectTab
    
    local collectButtonCorner = Instance.new("UICorner")
    collectButtonCorner.CornerRadius = UDim.new(0, 10)
    collectButtonCorner.Parent = collectButton
    
    -- ========== EVENT HANDLERS ==========
    
    -- Tab Switching
    flyTabButton.MouseButton1Click:Connect(function()
        flyTab.Visible = true
        collectTab.Visible = false
        flyTabButton.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
        collectTabButton.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        flyTabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        collectTabButton.TextColor3 = Color3.fromRGB(200, 200, 200)
    end)
    
    collectTabButton.MouseButton1Click:Connect(function()
        flyTab.Visible = false
        collectTab.Visible = true
        flyTabButton.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        collectTabButton.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
        flyTabButton.TextColor3 = Color3.fromRGB(200, 200, 200)
        collectTabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    
    -- Fly Speed Slider
    flySpeedSliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mouseX = input.Position.X
            local sliderX = flySpeedSliderBg.AbsolutePosition.X
            local sliderWidth = flySpeedSliderBg.AbsoluteSize.X
            local percentage = math.clamp((mouseX - sliderX) / sliderWidth, 0, 1)
            
            flySpeed = math.floor(percentage * 1000)
            flySpeedSlider.Size = UDim2.new(percentage, 0, 1, 0)
            flySpeedLabel.Text = "🚀 Fly Speed: " .. flySpeed
        end
    end)
    
    -- Height Speed Slider
    heightSpeedSliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mouseX = input.Position.X
            local sliderX = heightSpeedSliderBg.AbsolutePosition.X
            local sliderWidth = heightSpeedSliderBg.AbsoluteSize.X
            local percentage = math.clamp((mouseX - sliderX) / sliderWidth, 0, 1)
            
            heightSpeed = math.floor(percentage * 100)
            heightSpeedSlider.Size = UDim2.new(percentage, 0, 1, 0)
            heightSpeedLabel.Text = "⬆️ Up/Down Speed: " .. heightSpeed
        end
    end)
    
    -- Delay Slider
    delaySliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mouseX = input.Position.X
            local sliderX = delaySliderBg.AbsolutePosition.X
            local sliderWidth = delaySliderBg.AbsoluteSize.X
            local percentage = math.clamp((mouseX - sliderX) / sliderWidth, 0, 1)
            
            collectDelay = math.floor(percentage * 30) / 10
            if collectDelay < 0.1 then collectDelay = 0.1 end
            
            delaySlider.Size = UDim2.new(percentage, 0, 1, 0)
            delayLabel.Text = "⏱️ Delay: " .. collectDelay .. " sec"
        end
    end)
    
    -- Collect Button
    collectButton.MouseButton1Click:Connect(function()
        if autoCollecting then
            stopAutoCollect()
            collectButton.Text = "▶️ Start Auto-Collect"
            collectButton.BackgroundColor3 = Color3.fromRGB(50, 200, 100)
        else
            startAutoCollect()
            collectButton.Text = "⏸️ Stop Collecting"
            collectButton.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
        end
    end)
    
    -- Draggable
    local dragging = false
    local dragInput, mousePos, framePos
    
    titleLabel.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            mousePos = input.Position
            framePos = mainFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    titleLabel.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - mousePos
            mainFrame.Position = UDim2.new(
                framePos.X.Scale,
                framePos.X.Offset + delta.X,
                framePos.Y.Scale,
                framePos.Y.Offset + delta.Y
            )
        end
    end)
    
    screenGui.Parent = player.PlayerGui
end

-- ========== INPUT HANDLERS ==========
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- Q for flying (changed from E to avoid conflicts with Brainrot collection)
    if input.KeyCode == Enum.KeyCode.Q then
        if flying then
            stopFlying()
        else
            startFlying()
        end
    end
    
    if input.KeyCode == Enum.KeyCode.W then
        moveDirection.forward = true
    elseif input.KeyCode == Enum.KeyCode.S then
        moveDirection.backward = true
    elseif input.KeyCode == Enum.KeyCode.A then
        moveDirection.left = true
    elseif input.KeyCode == Enum.KeyCode.D then
        moveDirection.right = true
    elseif input.KeyCode == Enum.KeyCode.Space then
        moveDirection.up = true
    elseif input.KeyCode == Enum.KeyCode.LeftShift then
        moveDirection.down = true
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.W then
        moveDirection.forward = false
    elseif input.KeyCode == Enum.KeyCode.S then
        moveDirection.backward = false
    elseif input.KeyCode == Enum.KeyCode.A then
        moveDirection.left = false
    elseif input.KeyCode == Enum.KeyCode.D then
        moveDirection.right = false
    elseif input.KeyCode == Enum.KeyCode.Space then
        moveDirection.up = false
    elseif input.KeyCode == Enum.KeyCode.LeftShift then
        moveDirection.down = false
    end
end)

-- Update every frame
RunService.RenderStepped:Connect(function()
    updateFlyDirection()
end)

-- Handle character respawn
player.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    stopFlying()
    stopAutoCollect()
end)

