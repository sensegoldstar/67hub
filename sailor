local function scanAndAddMissingMobs()
    local seen = {}
    for prefix, _ in pairs(QUEST_MAP) do
        seen[prefix] = true
    end

    local foundNew = 0
    for _, obj in ipairs(Workspace_:GetDescendants()) do
        if obj:IsA("Model") and obj ~= Character and not string.find(obj.Name, "NPC") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            -- กรองเอาเฉพาะตัวที่มีเลือดเยอะกว่า 100 เพื่อตัดแม่ค้า/พ่อค้าออก (string.find("NPC") ถูกย้ายไปด้านบนแล้ว)
            if hum and hum.MaxHealth > 100 then
                local prefix = obj.Name:match("^(%a+)") or obj.Name:sub(1,8)
                if prefix ~= "" and not seen[prefix] then
                    seen[prefix] = true
                    foundNew = foundNew + 1
                    
                    local tgl = FarmTab:CreateToggle({
                        Name         = "🔍 [สแกนเจอ] " .. prefix,
                        CurrentValue = false,
                        Flag         = "MobToggle_Dynamic_" .. prefix,
                        Callback     = function(val)
