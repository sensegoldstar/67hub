local function getMobAnchor(obj)
    local anchor = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso") or obj:FindFirstChild("UpperTorso") or obj.PrimaryPart
    if anchor and anchor:IsA("BasePart") then return anchor end
    for _, child in ipairs(obj:GetChildren()) do
        if child:IsA("BasePart") then return child end
    end
    return nil
end

local mobCache = {}
local lastCacheTick = 0

-- ── ระบบค้นหามอนเจาะจงโฟลเดอร์ NPCs (เร็วสุดๆ และเจอ 100%) ────────────────
local function updateMobCache()
    local now = tick()
    if now - lastCacheTick < 1 then return end
    lastCacheTick = now
    
    local newCache = {}
    local myChar = LocalPlayer.Character
    _G.loadedSelectedPrefixes = {} 
    
    local searchList = {}
    local npcFolder = Workspace_:FindFirstChild("NPCs")
    if npcFolder then
        for _, child in ipairs(npcFolder:GetChildren()) do table.insert(searchList, child) end
    else
        for _, child in ipairs(Workspace_:GetChildren()) do if child:IsA("Model") then table.insert(searchList, child) end end
    end
    
    for _, obj in ipairs(searchList) do
        if obj and obj:IsA("Model") and obj ~= myChar and not string.find(obj.Name:lower(), "questnpc") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum then
                local cleanName = obj.Name:gsub("%s+", ""):lower()
                local isSelected = false
                
                for prefix, isEn in pairs(selectedMobPrefixes) do
                    if isEn then
                        local cleanPrefix = prefix:gsub("%s+", ""):lower()
                        if string.find(cleanName, cleanPrefix, 1, true) then
                            isSelected = true
                            _G.loadedSelectedPrefixes[prefix] = true
                            break
                        end
                    end
                end
                
                if isSelected and hum.Health > 0 then table.insert(newCache, obj) end
            end
        end
    end
    mobCache = newCache
end

local currentMobTarget = nil
local function findNearestSelectedMob()
    updateMobCache()
    Character = LocalPlayer.Character or Character
    local root = Character and Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    if currentMobTarget and currentMobTarget.Parent then
        local targetHum = currentMobTarget:FindFirstChildOfClass("Humanoid")
        if targetHum and targetHum.Health > 0 then
            local stillExists = false
            for _, m in ipairs(mobCache) do if m == currentMobTarget then stillExists = true; break end end
            if stillExists then return currentMobTarget end
        end
    end
    
    local nearest, bestDist = nil, math.huge
    for _, obj in ipairs(mobCache) do
        if obj and obj.Parent then
            local anchor = getMobAnchor(obj)
            local hum    = obj:FindFirstChildOfClass("Humanoid")
            if anchor and hum and hum.Health > 0 then
                local d = (anchor.Position - root.Position).Magnitude
                if d < bestDist then nearest = obj; bestDist = d end
            end
        end
    end
    currentMobTarget = nearest
    return nearest
end

local function teleportBehindMob(mob)
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root   = Character and Character:FindFirstChild("HumanoidRootPart")
    local anchor = getMobAnchor(mob)
    
    if root and anchor and anchor:IsA("BasePart") then
        local offset = math.max(1.5, attackRange - 1)
        local targetCFrame = nil
        if teleportPosition == "ด้านบน (Above)" then targetCFrame = CFrame.lookAt((anchor.CFrame * CFrame.new(0, offset, 0)).Position, anchor.Position)
        elseif teleportPosition == "ด้านล่าง (Below)" then targetCFrame = CFrame.lookAt((anchor.CFrame * CFrame.new(0, -offset, 0)).Position, anchor.Position)
        else targetCFrame = CFrame.lookAt((anchor.CFrame * CFrame.new(0, 0, offset)).Position, anchor.Position) end
        
        local dist = (root.Position - anchor.Position).Magnitude
        if dist > 1500 then
            local targetIsland = nil
            local cleanName = mob.Name:gsub("%s+", ""):lower()
            for prefix, mapped in pairs(QUEST_MAP) do
                if string.find(cleanName, prefix:gsub("%s+", ""):lower(), 1, true) then targetIsland = mapped.island; break end
            end
            if targetIsland then HopToIsland(targetIsland) end
            return false
        else
            if _G.isIslandHopping then return false end
            local distFromTarget = (root.Position - targetCFrame.Position).Magnitude
            if distFromTarget > 1 then
                if not _G.isTweening then task.spawn(function() TweenFunction(targetCFrame) end) end
                return false
            else
                return true
            end
        end
    end
    return false
end

local CombatRemote = ReplicatedStorage:WaitForChild("CombatSystem"):WaitForChild("Remotes"):WaitForChild("RequestHit")
local function attackMob(mob)
    local root   = Character and Character:FindFirstChild("HumanoidRootPart")
    local mobHRP = mob:FindFirstChild("HumanoidRootPart")
    if not root or not mobHRP then return end
    pcall(function() root.CFrame = CFrame.lookAt(root.Position, mobHRP.Position) end)
    pcall(function() CombatRemote:FireServer() end)
end

FarmTab:CreateToggle({
    Name         = "🗡️ Auto Farm (เปิด/ปิด)",
    CurrentValue = false,
    Flag         = "AutoFarmToggle",
    Callback     = function(val)
        autoFarmEnabled = val
        if val then
            local anySelected = false
            for k, v in pairs(selectedMobPrefixes) do if v then anySelected = true; break end end
            if not anySelected then Rayfield:Notify({ Title = "⚠️ เลือก Mob ก่อน!", Content = "Scan Mob หรือติ๊กเลือกมอนที่ต้องการฟาร์มก่อนเริ่ม", Duration = 4 }); autoFarmEnabled = false; return end
            if farmConnection then farmConnection:Disconnect(); farmConnection = nil end

            farmConnection = RunService.Heartbeat:Connect(function(dt)
                if not autoFarmEnabled then return end
                if _G.isTweening or _G.isIslandHopping then return end
                
                local success, err = pcall(function()
                    Character = LocalPlayer.Character
                    local root = Character and Character:FindFirstChild("HumanoidRootPart")
                    if not root then return end
                    
                    local bv = root:FindFirstChild("FarmFloat")
                    if not bv then bv = Instance.new("BodyVelocity"); bv.Name = "FarmFloat"; bv.MaxForce = Vector3.new(100000, 100000, 100000); bv.Velocity = Vector3.new(0, 0, 0); bv.Parent = root end

                    local mob = findNearestSelectedMob()
                    if mob then
                        local hum    = mob:FindFirstChildOfClass("Humanoid")
                        local hp     = math.floor(hum and hum.Health or 0)
                        local maxHP  = math.floor(hum and hum.MaxHealth or 0)
                        
                        local cleanName = mob.Name:gsub("%s+", "")
                        local matchedPrefix = ""
                        for prefix, _ in pairs(selectedMobPrefixes) do
                            if string.find(cleanName, prefix, 1, true) then matchedPrefix = prefix; break end
                        end
                        local qi = QUEST_MAP[matchedPrefix]

                        pcall(function()
                            if tick() - (_G.lastFarmStatusUpdate or 0) > 0.3 then
                                _G.lastFarmStatusUpdate = tick()
                                FarmStatus:Set({ Title = "⚔️ กำลัง Farm", Content = mob.Name .. "  HP: " .. hp .. "/" .. maxHP .. "\nระยะ: " .. attackRange .. " studs" .. (qi and ("\nQuest: " .. qi.label) or "") })
                            end
                        end)

                        if teleportBehindMob(mob) then attackMob(mob) end

                        skillCooldownTimer = skillCooldownTimer + dt
                        if skillCooldownTimer > 1.5 then 
                            local keyToPress = skillOrder[currentSkillIdx]
                            if autoSkills[keyToPress] then
                                VirtualInputMngr:SendKeyEvent(true, skillKeycodes[keyToPress], false, game)
                                task.wait(0.05)
                                VirtualInputMngr:SendKeyEvent(false, skillKeycodes[keyToPress], false, game)
                                skillCooldownTimer = 0 
                            end
                            currentSkillIdx = currentSkillIdx + 1
                            if currentSkillIdx > #skillOrder then currentSkillIdx = 1 end
                        end
                    else
                        if not _G.isIslandHopping then
                            pcall(function()
                                if tick() - (_G.lastFarmStatusUpdate or 0) > 0.3 then
                                    _G.lastFarmStatusUpdate = tick()
                                    FarmStatus:Set({ Title = "🔍 หามอน...", Content = "ค้นหาแบบเจาะจงโฟลเดอร์ NPCs ไม่พบมอน — กำลังเช็คเกาะ..." })
                                end
                            end)
                            
                            local targetIsland = nil
                            for prefix, isEn in pairs(selectedMobPrefixes) do
                                if isEn and QUEST_MAP[prefix] and QUEST_MAP[prefix].island then
                                    if not _G.loadedSelectedPrefixes or not _G.loadedSelectedPrefixes[prefix] then
                                        targetIsland = QUEST_MAP[prefix].island
                                        break 
                                    end
                                end
                            end
                            if targetIsland then HopToIsland(targetIsland) end
                        end
                    end
                end)
            end)
        else
            _G.isTweening = false
            if _G.currentTween then pcall(function() _G.currentTween:Cancel() end) end
            if farmConnection then farmConnection:Disconnect(); farmConnection = nil end
            pcall(function() if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then local bv = LocalPlayer.Character.HumanoidRootPart:FindFirstChild("FarmFloat"); if bv then bv:Destroy() end end end)
            pcall(function() FarmStatus:Set({ Title = "สถานะ", Content = "ปิดอยู่ — พักเบรก" }) end)
        end
    end,
})

